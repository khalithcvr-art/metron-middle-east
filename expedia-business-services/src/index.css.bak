@tailwind base;
@tailwind components;
@tailwind utilities;

@keyframes marquee {
  0% { transform: translateX(0); }
  100% { transform: translateX(-50%); }
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(30px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes countUp {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

@keyframes shimmer {
  0%, 100% {
    background-position: 0% center;
  }
  50% {
    background-position: 100% center;
  }
}

@keyframes slideInFromLeft {
  from {
    opacity: 0;
    transform: translateX(-40px);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}

@keyframes slideInFromRight {
  from {
    opacity: 0;
    transform: translateX(40px);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}

@keyframes glow {
  0%, 100% {
    box-shadow: 0 0 20px rgba(245, 158, 11, 0.15);
  }
  50% {
    box-shadow: 0 0 30px rgba(245, 158, 11, 0.25);
  }
}

@keyframes slideUp {
  from {
    max-height: 0;
    opacity: 0;
  }
  to {
    max-height: 500px;
    opacity: 1;
  }
}

.animate-marquee {
  animation: marquee 35s linear infinite;
}

.animate-marquee:hover {
  animation-play-state: paused;
}

.animate-fade-in-up {
  animation: fadeInUp 0.6s ease-out forwards;
}

.animate-shimmer {
  background-size: 200% 100%;
  animation: shimmer 3s infinite;
}

.animate-glow {
  animation: glow 2s ease-in-out infinite;
}

.scroll-animation {
  opacity: 0;
  animation: fadeInUp 0.8s ease-out forwards;
}

.nav-indicator {
  position: absolute;
  bottom: 0;
  height: 2px;
  background: linear-gradient(90deg, #F59E0B, #D4A017);
  transition: all 0.3s ease;
}

.scroll-progress {
  position: fixed;
  top: 0;
  left: 0;
  height: 2px;
  background: linear-gradient(90deg, #F59E0B, #D4A017);
  z-index: 100;
  transition: width 0.2s ease;
}

.gradient-text-shimmer {
  background: linear-gradient(90deg, #F59E0B, #D4A017, #F59E0B);
  background-size: 200% 100%;
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  animation: shimmer 3s infinite;
}

@keyframes gradientShift {
  0% {
    background-position: 0% 50%;
  }
  50% {
    background-position: 100% 50%;
  }
  100% {
    background-position: 0% 50%;
  }
}

@keyframes float {
  0%, 100% {
    transform: translateY(0px);
  }
  50% {
    transform: translateY(-20px);
  }
}

@keyframes pulse-glow {
  0%, 100% {
    box-shadow: 0 0 20px rgba(245, 158, 11, 0.1), inset 0 0 20px rgba(245, 158, 11, 0.05);
  }
  50% {
    box-shadow: 0 0 40px rgba(245, 158, 11, 0.2), inset 0 0 30px rgba(245, 158, 11, 0.1);
  }
}

@keyframes tilt-shimmer {
  0%, 100% {
    background-position: 0% 0%;
  }
  100% {
    background-position: 100% 100%;
  }
}

@keyframes gradient-rotate {
  0% {
    background-position: 0% 50%;
  }
  50% {
    background-position: 100% 50%;
  }
  100% {
    background-position: 0% 50%;
  }
}

@keyframes neon-pulse {
  0%, 100% {
    text-shadow: 0 0 10px rgba(245, 158, 11, 0.5), 0 0 20px rgba(245, 158, 11, 0.3);
  }
  50% {
    text-shadow: 0 0 20px rgba(245, 158, 11, 0.8), 0 0 40px rgba(245, 158, 11, 0.5);
  }
}

@keyframes float-rotate {
  0% {
    transform: translateY(0px) rotate(0deg);
  }
  50% {
    transform: translateY(-15px) rotate(5deg);
  }
  100% {
    transform: translateY(0px) rotate(0deg);
  }
}

@keyframes border-glow {
  0%, 100% {
    border-color: rgba(245, 158, 11, 0.2);
    box-shadow: 0 0 15px rgba(245, 158, 11, 0.1);
  }
  50% {
    border-color: rgba(245, 158, 11, 0.5);
    box-shadow: 0 0 30px rgba(245, 158, 11, 0.3);
  }
}

.animate-gradient-shift {
  background-size: 200% 200%;
  animation: gradient-shift 6s ease infinite;
}

.animate-float {
  animation: float 6s ease-in-out infinite;
}

.animate-pulse-glow {
  animation: pulse-glow 3s ease-in-out infinite;
}

.animate-neon-pulse {
  animation: neon-pulse 2.5s ease-in-out infinite;
}

.animate-float-rotate {
  animation: float-rotate 8s ease-in-out infinite;
}

.animate-border-glow {
  animation: border-glow 3s ease-in-out infinite;
}

.glassmorphism {
  background: rgba(255, 255, 255, 0.05);
  backdrop-filter: blur(10px);
  border: 1px solid rgba(255, 255, 255, 0.1);
}

.glassmorphism-dark {
  background: rgba(13, 19, 33, 0.4);
  backdrop-filter: blur(8px);
  border: 1px solid rgba(245, 158, 11, 0.1);
}

.depth-shadow-lg {
  box-shadow:
    0 10px 30px rgba(0, 0, 0, 0.3),
    0 0 60px rgba(245, 158, 11, 0.05);
}

.depth-shadow-sm {
  box-shadow:
    0 5px 15px rgba(0, 0, 0, 0.2),
    0 0 30px rgba(245, 158, 11, 0.03);
}

.perspective-transform {
  perspective: 1000px;
  transform-style: preserve-3d;
  transition: transform 0.6s cubic-bezier(0.23, 1, 0.320, 1);
}

.perspective-transform:hover {
  transform: rotateX(5deg) rotateY(-5deg) scale(1.02);
}

.neon-border {
  border: 2px solid transparent;
  background-clip: padding-box;
  position: relative;
}

.neon-border::before {
  content: '';
  position: absolute;
  top: -2px;
  left: -2px;
  right: -2px;
  bottom: -2px;
  background: linear-gradient(45deg, rgba(245, 158, 11, 0.3), rgba(245, 158, 11, 0.1));
  border-radius: inherit;
  z-index: -1;
  animation: border-glow 3s ease-in-out infinite;
}

.smooth-transition {
  transition: all 0.4s cubic-bezier(0.23, 1, 0.320, 1);
}

.glow-effect {
  position: relative;
  overflow: hidden;
}

.glow-effect::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 200px;
  height: 200px;
  background: radial-gradient(circle, rgba(245, 158, 11, 0.2), transparent);
  border-radius: 50%;
  transform: translate(-50%, -50%);
  opacity: 0;
  transition: opacity 0.3s ease;
  pointer-events: none;
}

.glow-effect:hover::before {
  opacity: 1;
}

@keyframes parallax {
  0% {
    transform: translateY(0px);
  }
  100% {
    transform: translateY(30px);
  }
}

@keyframes stagger-in {
  0% {
    opacity: 0;
    transform: translateY(20px);
  }
  100% {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes float-smooth {
  0%, 100% {
    transform: translateY(0px);
  }
  33% {
    transform: translateY(-8px);
  }
  66% {
    transform: translateY(-4px);
  }
}

@keyframes float-smooth-slow {
  0%, 100% {
    transform: translateY(0px);
  }
  33% {
    transform: translateY(-12px);
  }
  66% {
    transform: translateY(-6px);
  }
}

@keyframes morph {
  0%, 100% {
    border-radius: 60% 40% 30% 70% / 60% 30% 70% 40%;
  }
  25% {
    border-radius: 30% 60% 70% 40% / 50% 60% 30% 60%;
  }
  50% {
    border-radius: 70% 30% 40% 60% / 30% 60% 60% 40%;
  }
  75% {
    border-radius: 40% 70% 60% 30% / 70% 40% 30% 60%;
  }
}

@keyframes morph-scale {
  0%, 100% {
    transform: scale(1);
    border-radius: 60% 40% 30% 70% / 60% 30% 70% 40%;
  }
  25% {
    transform: scale(1.05);
    border-radius: 30% 60% 70% 40% / 50% 60% 30% 60%;
  }
  50% {
    transform: scale(0.95);
    border-radius: 70% 30% 40% 60% / 30% 60% 60% 40%;
  }
  75% {
    transform: scale(1.02);
    border-radius: 40% 70% 60% 30% / 70% 40% 30% 60%;
  }
}

@keyframes slide-up {
  0% {
    opacity: 0;
    transform: translateY(40px);
  }
  100% {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes slide-left {
  0% {
    opacity: 0;
    transform: translateX(40px);
  }
  100% {
    opacity: 1;
    transform: translateX(0);
  }
}

@keyframes slide-right {
  0% {
    opacity: 0;
    transform: translateX(-40px);
  }
  100% {
    opacity: 1;
    transform: translateX(0);
  }
}

@keyframes scale-in {
  0% {
    opacity: 0;
    transform: scale(0.95);
  }
  100% {
    opacity: 1;
    transform: scale(1);
  }
}

@keyframes gradient-flow {
  0% {
    background-position: 0% 50%;
  }
  25% {
    background-position: 50% 25%;
  }
  50% {
    background-position: 100% 50%;
  }
  75% {
    background-position: 50% 75%;
  }
  100% {
    background-position: 0% 50%;
  }
}

@keyframes gradient-glow-pulse {
  0%, 100% {
    background-position: 0% 50%;
    filter: drop-shadow(0 0 10px rgba(245, 158, 11, 0.2));
  }
  50% {
    background-position: 100% 50%;
    filter: drop-shadow(0 0 20px rgba(245, 158, 11, 0.4));
  }
}

.animate-parallax {
  animation: parallax linear forwards;
}

.animate-stagger-in-1 {
  animation: stagger-in 0.6s ease-out forwards;
  animation-delay: 0s;
}

.animate-stagger-in-2 {
  animation: stagger-in 0.6s ease-out forwards;
  animation-delay: 0.1s;
}

.animate-stagger-in-3 {
  animation: stagger-in 0.6s ease-out forwards;
  animation-delay: 0.2s;
}

.animate-stagger-in-4 {
  animation: stagger-in 0.6s ease-out forwards;
  animation-delay: 0.3s;
}

.animate-float-smooth {
  animation: float-smooth 4s ease-in-out infinite;
}

.animate-float-smooth-slow {
  animation: float-smooth-slow 6s ease-in-out infinite;
}

.animate-morph {
  animation: morph 8s ease-in-out infinite;
}

.animate-morph-scale {
  animation: morph-scale 10s ease-in-out infinite;
}

.animate-slide-up {
  animation: slide-up 0.6s ease-out forwards;
}

.animate-slide-left {
  animation: slide-left 0.6s ease-out forwards;
}

.animate-slide-right {
  animation: slide-right 0.6s ease-out forwards;
}

.animate-scale-in {
  animation: scale-in 0.6s ease-out forwards;
}

.animate-gradient-flow {
  background-size: 200% 200%;
  animation: gradient-flow 8s ease infinite;
}

.animate-gradient-glow-pulse {
  background-size: 200% 200%;
  animation: gradient-glow-pulse 4s ease-in-out infinite;
}

@supports (backdrop-filter: blur(10px)) {
  .glassmorphism {
    background: rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(10px);
  }

  .glassmorphism-dark {
    background: rgba(13, 19, 33, 0.4);
    backdrop-filter: blur(8px);
  }
}
